<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:st="jelly:stapler" xmlns:l="/lib/layout" xmlns:f="/lib/form">
    <st:setHeader name="X-Wizard-Title" value="${%Move credentials}" />

    <l:ajax>
        <f:form id="credentials-dialog-form" action="doMove" method="POST" name="moveCredentials">
            <p>${%blurb(it.displayName,it.typeName)}</p>
            <div class="jenkins-form-item">
                <div class="jenkins-select">
                    <select name="destination" class="jenkins-select__input">
                        <j:forEach var="destination" items="${it.domain.parent.domains.values()}">
                            <j:choose>
                                <j:when test="${destination.domain == it.domain.domain}">
                                    <option selected="yes" value="${destination.fullName}">
                                        ${app.displayName} &#187; ${destination.fullDisplayName}
                                    </option>
                                </j:when>
                                <j:otherwise>
                                    <option value="${destination.fullName}">
                                        ${app.displayName} &#187; ${destination.fullDisplayName}
                                    </option>
                                </j:otherwise>
                            </j:choose>
                        </j:forEach>
                    </select>
                </div>
            </div>

            <f:bottomButtonBar borderless="true">
                <button id="cr-dialog-submit" class="jenkins-button jenkins-button--primary cr-bottom-button">${%Move}</button>
            </f:bottomButtonBar>
        </f:form>
    </l:ajax>
</j:jelly>
